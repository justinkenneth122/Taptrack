        <div class="admin-main">
            <div class="admin-header">
                <span class="text-sm font-medium text-muted">Admin Panel</span>
            </div>
            <div class="admin-content">
                <?php
                switch ($subpage) {
                    case 'home': renderAdminHome($pdo); break;
                    case 'events': renderAdminEvents($pdo); break;
                    case 'qr_generator': renderAdminQRGenerator($pdo); break;
                    case 'qr_scanner': renderAdminQRScanner($pdo); break;
